<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.ucv.lab12.controller.VideojuegoFormController"
      spacing="14"
      style="-fx-padding:24; -fx-background-color:white;"
      prefWidth="480">

    <Label fx:id="lblTitulo" text="Videojuego"
           style="-fx-font-size:20; -fx-font-weight:bold; -fx-text-fill:#1565C0;">
        <font><Font size="20.0"/></font>
    </Label>
    <Separator/>

    <GridPane hgap="12" vgap="10">
        <columnConstraints>
            <ColumnConstraints minWidth="130" prefWidth="140" halignment="RIGHT"/>
            <ColumnConstraints hgrow="ALWAYS" minWidth="260"/>
        </columnConstraints>

        <Label text="Consola: *" GridPane.rowIndex="0" GridPane.columnIndex="0"
               style="-fx-font-weight:bold;"/>
        <VBox GridPane.rowIndex="0" GridPane.columnIndex="1" spacing="2">
            <TextField fx:id="txtConsola" promptText="Ingrese consola..." maxWidth="Infinity"/>
            <Label fx:id="lblConsolaError" text=""
                   style="-fx-text-fill:#C62828; -fx-font-size:11;" visible="false"/>
        </VBox>

        <Label text="Nombre: *" GridPane.rowIndex="1" GridPane.columnIndex="0"
               style="-fx-font-weight:bold;"/>
        <VBox GridPane.rowIndex="1" GridPane.columnIndex="1" spacing="2">
            <TextField fx:id="txtNombre" promptText="Ingrese nombre..." maxWidth="Infinity"/>
            <Label fx:id="lblNombreError" text=""
                   style="-fx-text-fill:#C62828; -fx-font-size:11;" visible="false"/>
        </VBox>

        <Label text="Genero:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <TextField fx:id="txtGenero" promptText="Ingrese genero..."
                   GridPane.rowIndex="2" GridPane.columnIndex="1"/>

        <Label text="Clasificacion:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <TextField fx:id="txtClasificacion" promptText="Ingrese clasificacion..."
                   GridPane.rowIndex="3" GridPane.columnIndex="1"/>

        <Label text="Descripcion:" GridPane.rowIndex="4" GridPane.columnIndex="0"
               GridPane.valignment="TOP"/>
        <TextArea fx:id="txtDescripcion" promptText="Ingrese descripcion..."
                  GridPane.rowIndex="4" GridPane.columnIndex="1"
                  prefHeight="68" wrapText="true"/>

        <Label text="ID Desarrollador: *" GridPane.rowIndex="5" GridPane.columnIndex="0"
               style="-fx-font-weight:bold;"/>
        <VBox GridPane.rowIndex="5" GridPane.columnIndex="1" spacing="2">
            <TextField fx:id="txtIdDesarrollador" promptText="Ingrese ID desarrollador..." maxWidth="Infinity"/>
            <Label fx:id="lblIdDesarrolladorError" text=""
                   style="-fx-text-fill:#C62828; -fx-font-size:11;" visible="false"/>
        </VBox>

        <Label text="Distribuidor: *" GridPane.rowIndex="6" GridPane.columnIndex="0"
               style="-fx-font-weight:bold;"/>
        <VBox GridPane.rowIndex="6" GridPane.columnIndex="1" spacing="2">
            <ComboBox fx:id="cboDistribuidor" promptText="Seleccione distribuidor" maxWidth="Infinity"/>
            <Label fx:id="lblDistribuidorError" text=""
                   style="-fx-text-fill:#C62828; -fx-font-size:11;" visible="false"/>
        </VBox>
    </GridPane>

    <Label text="(*) Campo obligatorio"
           style="-fx-font-size:11; -fx-text-fill:#757575;"/>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button fx:id="btnCancelar" text="Cancelar" onAction="#onCancelar"
                prefWidth="100"
                style="-fx-cursor:hand;"/>
        <Button text="Guardar" onAction="#onGuardar"
                defaultButton="true" prefWidth="100"
                style="-fx-background-color:#1976D2;-fx-text-fill:white;-fx-cursor:hand;-fx-font-weight:bold;"/>
    </HBox>
</VBox>
